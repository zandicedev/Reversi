CFLAGS = -std=c11 -ggdb -Wall -Wpedantic -Wextra -g 
CPPFLAGS = -I../include -DDEBUG
LDFLAGS = 

all: board_tests

board_tests: board_tests.o board.o
	$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)

board_tests.o: board_tests.c ../include/board.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c $<

board.o: ../src/board.c ../include/board.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c $<

clean:
	rm -f *.o board_tests

help:
	@echo "Usage:"
	@echo " make [all]\t\tBuild the software"
	@echo " make clean\t\tRemove all files generated by make"
	@echo " make help\t\tDisplay this help"

.PHONY: all clean help